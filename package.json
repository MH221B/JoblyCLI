{
  "name": "jobly-mcp",
  "version": "2.0.0",
  "description": "Setup JoblyAI MCP server in your OpenCode, Claude Code, or Codex CLI config",
  "type": "module",
  "bin": {
    "jobly-mcp": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "jobly.ai.vn",
  "repository": {
    "type": "git",
    "url": "https://github.com/jobly-ai/jobly-mcp.git"
  },
  "homepage": "https://jobly.ai.vn",
  "keywords": [
    "jobly",
    "joblyai",
    "mcp",
    "model-context-protocol",
    "opencode",
    "claude",
    "claude-code",
    "codex",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.7.0",
    "strip-json-comments": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
